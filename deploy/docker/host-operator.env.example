AGENT_IMAGE=unboxdcloudplatform/canonical-microcloud-agent:latest

# Remote execution is the preferred Docker operator model.
REMOTE_EXEC_PREFIX=ssh -i /run/agent-ssh/id_ed25519 -o StrictHostKeyChecking=accept-new
OPERATOR_SSH_TARGET=ubuntu@your-microcloud-host
MICROCLOUD_SSH_TARGET=ubuntu@your-microcloud-host
LXC_SSH_TARGET=ubuntu@your-microcloud-host

# Remote host binaries.
MICROCLOUD_BIN=/snap/bin/microcloud
LXC_BIN=lxc
DOCKER_BIN=docker
SNAP_BIN=snap
PRIVILEGE_EXEC_PREFIX=sudo
VPN_BIN=tailscale
DNS_BIN=resolvectl
DIG_BIN=dig
REVERSEPROXY_MODE=caddy
CADDY_BIN=caddy
CADDYFILE_PATH=/etc/caddy/Caddyfile
COMPUTERUSE_BIN=computer-use

# Agent runtime.
AK_API__HOST=0.0.0.0
AK_API__PORT=8000
AGENTKERNEL_AGENT_NAME=microcloud-operator
AGENTKERNEL_DEFAULT_ENVIRONMENT=lab
AGENTKERNEL_DEFAULT_INVENTORY=ansible/inventories/lab/hosts.ini
AGENTKERNEL_DEFAULT_TERRAFORM_DIR=terraform/environments/lab
MICROCLOUD_AGENT_APPROVAL=

# Optional integrations.
MATTERMOST_WEBHOOK_URL=
MATTERMOST_CHANNEL=
MATTERMOST_USERNAME=canonical-microcloud-agent
OIDC_ISSUER_URL=
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_SCOPE=
OPENAPI_BASE_URL=
OPENAPI_BEARER_TOKEN=
